#. Plugin Name of the plugin
#: w3tc-webp-helper.php
msgid "W3TC WebP Helper"
msgstr "W3TC WebP-Helfer"

#. Plugin URI of the plugin
#: w3tc-webp-helper.php
msgid "https://sevmatic.com/?plugin=w3tc-webp-helper&source=wordpress"
msgstr "https://sevmatic.com/?plugin=w3tc-webp-helper&source=wordpress"

#. Description of the plugin
#: w3tc-webp-helper.php
msgid ""
"Replaces image URLs in post content with WebP versions when the browser "
"supports WebP, based on W3 Total Cache ImageService conversion status."
msgstr ""
"Ersetzt Bild-URLs im Beitragsinhalt durch WebP-Versionen, sofern der "
"Browser WebP unterstützt und die Bilder vom W3 Total Cache ImageService "
"konvertiert wurden."

